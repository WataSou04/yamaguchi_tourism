<div class="container">
  <div class="row">
    <h5><%= @customer.last_name %> <%= @customer.first_name %>さんの会員情報編集</h5>
  </div>
  <div class="row">
    <table>
      <tr><td>会員ID</td><td><%= @customer.id %></td></tr>
      <%= form_with model: @customer, url: admin_customer_path, method: :patch do |f| %>
      <tr><td><label for="Name">氏名</label></td><td><%= f.text_field :last_name, autofocus: true, id:"Name" %> <%= f.text_field :first_name, autofocus: true, id:"Name" %></td></tr>
      <tr><td><label for="Name_kana">フリガナ</label></td><td><%= f.text_field :last_name_kana, autofocus: true, id:"Name_kana" %> <%= f.text_field :first_name_kana, autofocus: true, id:"Name_kana" %></td></tr>
      <tr><td><label for="Email">メールアドレス</label></td><td><%= f.text_field :email, autofocus: true, id:"Email" %></td></tr>
      <tr><td>会員ステータス</td><td><%= f.radio_button :is_active, :true, id:"active" %><label for="active">有効</label><%= f.radio_button :is_active, :false, id:"withdrawal" %><label for="withdrawal">退会</td></tr>
    </table>
  </div>
      <%= f.submit "変更を保存", class: 'btn btn-success' %>
      <% end %>
</div>