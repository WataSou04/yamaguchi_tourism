<div class="container">
  <div class="row">
    <h5>会員一覧</h5>
  </div>
  <dvi class="row">
    <table>
      <tr><td>会員ID</td><td>氏名</td><td>メールアドレス</td><td>ステータス</td></tr>
      <% @customers.each do |customer| %>
      <tr><td><%= customer.id %></td><td><%= link_to "#{customer.last_name}#{customer.first_name}", admin_customer_path(customer.id) %></td><td><%= customer.email %></td><td><%= customer.is_active ? '有効' : '退会' %></td></tr>
      <% end %>
    </table>
  </dvi>
</div>