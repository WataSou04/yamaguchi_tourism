<div class="container">
  <div class="row no-gutters">
    <div class="col-md-5 col-sm-10 mx-2 mx-sm-auto shadow-lg rounded px-0 my-5">
      <h5 class="text-dark bg-light p-4 mb-0"><%= @customer.last_name %><%= @customer.first_name %>さんの会員詳細</h5>
      <div class="form-body p-4">
      <div class="input-group mb-3 mt-4">
        <div class="input-group-prepend">
          <span class="input-group-text" aria-hidden="true"><i class="fas fa-building"></i></span>
        </div>
        <%= @customer.id %>
      </div>
      <div class="input-group mb-3 mt-4">
        <div class="input-group-prepend">
          <span class="input-group-text" aria-hidden="true"><i class="fas fa-building"></i></span>
        </div>
        <%= @customer.last_name %> <%= @customer.first_name %>
      </div>
      <div class="input-group mb-3 mt-4">
        <div class="input-group-prepend">
          <span class="input-group-text" aria-hidden="true"><i class="fas fa-building"></i></span>
        </div>
        <%= @customer.email %>
      </div>
      <div class="input-group mb-3 mt-4">
        <div class="input-group-prepend">
          <span class="input-group-text" aria-hidden="true"><i class="fas fa-building"></i></span>
        </div>
        <%= @customer.is_active ? '有効' : '退会' %>
      </div>
      </div>
      <%= link_to '編集する', edit_admin_customer_path(@customer.id), class: 'btn btn-success' %>
    </div>
  </div>
</div>