<div class="container">
  <div class="row mt-5">
    <div class="col-12">
      <h1><strong><%= @tourist_spot.name %></strong></h1>
      <h5><%= @tourist_spot.address %></h5>
    </div>
  </div>
  <div class="row mt-3">
    <div class="col-md-7">
      <%= image_tag @tourist_spot.image, size: "600x450", class: 'rounded' %>
    </div>
    <div class="col-md-5 shadow rounded-3 pt-3 position-relative">
      <div>
        <h3>ガイド</h3>
      </div>
      <div>
        <p><%= @tourist_spot.explanation %></p>
      </div>
      <div class="align-self-end">
        <%= link_to "編集する", edit_admin_tourist_spot_path, class: 'btn btn-lg btn-block btn-primary' %>
      </div>
    </div>
  </div>
</div>