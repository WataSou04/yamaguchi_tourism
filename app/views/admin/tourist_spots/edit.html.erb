<div class="container">
  <div class="row">
    <h5>観光地情報編集</h5>
  </div>
  <div class="row">
    <%= form_with model: @tourist_spot, url: admin_tourist_spot_path, method: :patch do |f| %>
    <table>
      <tr><td>観光地画像</td><td><%= f.file_field :image, accept: "image/*" %></td></tr>
      <tr><td>観光地名</td><td><%= f.text_field :name %></td></tr>
      <tr><td>観光地情報</td><td><%= f.text_area :explanation %></td></tr>
      <tr><td>住所</td><td><%= f.text_field :address %></td></tr>
      <tr><td>おすすめ季節</td><td><%= f.radio_button :season, :spring, id:"spring" %><label for="spring">春</label>
                                   <%= f.radio_button :season, :summer, id:"summer" %><label for="summer">夏</label>
                                   <%= f.radio_button :season, :autumn, id:"autumn" %><label for="autumn">秋</label>
                                   <%= f.radio_button :season, :winter, id:"winter" %><label for="winter">冬</label></td></tr>
    </table>
    <%= f.submit "変更を保存", class: 'btn btn-success' %><%= link_to "削除する", admin_tourist_spot_path, method: :delete, class: 'btn btn-danger' %>
    <% end %>
  </div>
</div>